            { "n": "LAST_NAME",            "t": "",   "dt": "varchar",  "pi": true,  "masked": true  },
            { "n": "DATE_OF_BIRTH",        "t": "",   "dt": "date",     "pi": true,  "masked": true,  "note": "DOB — PI, masked" },
            { "n": "CREATED_AT",           "t": "",   "dt": "datetime", "pi": false, "masked": false },
            { "n": "UPDATED_AT",           "t": "",   "dt": "datetime", "pi": false, "masked": false },
            { "n": "IS_ACTIVE",            "t": "",   "dt": "boolean",  "pi": false, "masked": false }
          ]
        },
        {
